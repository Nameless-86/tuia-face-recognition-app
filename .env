APP_NAME=Facial Recognition TP1
SIMILARITY_METRIC=cosine
SIMILARITY_THRESHOLD=0.389
EMBEDDINGS_PATH=data/embeddings.json
DATA_PATH=data
OUTPUT_PATH=output
# Orígenes permitidos para CORS (coma). Use * en desarrollo.
CORS_ORIGINS="http://localhost:8080"
MODEL_PATH=models
MODEL_NAME=face_vit_ft_aligned.pth
MAX_WORKERS=2
FACE_SIZE=160
EMBEDDING_DIM=768

# PostgreSQL / pgvector
USE_PGVECTOR=true
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=faces
POSTGRES_USER=faces_user    
POSTGRES_PASSWORD=faces_pass